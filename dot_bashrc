export PATH=$PATH:/usr/local/texlive/2025/bin/x86_64-linux
export EDITOR=nvim
export RUBYOPT="-W0"

# pnpm
export PNPM_HOME="/home/finn/.local/share/pnpm"
case ":$PATH:" in
*":$PNPM_HOME:"*) ;;
*) export PATH="$PNPM_HOME:$PATH" ;;
esac

# Aliases
alias ff="fzf --style full --bind 'focus:transform-header:file --brief {}'"

alias ls='eza'
