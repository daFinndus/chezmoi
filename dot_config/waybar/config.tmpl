{
  {{- if eq .device "krabby" }}
  "output": "DP-3",
  {{- end }}
  {{- if eq .device "kabuki" }}
  "output": "eDP-1",
  {{- end }}
  "layer": "bottom",
  "position": "top",
  "margin": "8 8 0 8",
  "spacing": 4,
  "include": ["/home/finn/.config/waybar/modules.json"],
  "modules-left": [
    "clock",
    "hyprland/workspaces",
    "idle_inhibitor",
    "power-profiles-daemon",
    "custom/updater"
  ],
  "modules-right": [
    "tray",
    "custom/vpn",
    "network",
    "pulseaudio",
    {{- if eq .device "kabuki" }}
    "battery",
    {{ end }}
    "custom/power"
  ],
}
