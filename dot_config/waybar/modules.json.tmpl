{
  "network": {
    "format-wifi": "{essid} at {signalStrength}%",
    "format-ethernet": "Connected via ethernet",
    "format-disconnected": "No network",
    "format-disabled": "Interface disabled",
    "on-click-right": "kitty --title iwctl --class kitty -e iwctl",
    "tooltip": true,
    "tooltip-format": "{ipaddr}/{cidr} via {gwaddr}",
    "tooltip-format-disconnected": "Nothing is connected with an interface",
  },
  "idle_inhibitor": {
    "format": "Inhibitor: {icon}",
    "format-icons": {
      "activated": "Activated",
      "deactivated": "Deactivated",
    },
    "tooltip": false,
  },
  "pulseaudio": {
    "format": "Volume at {volume}%",
    "format-muted": "Volume muted",
    "format-bluetooth": "Connected via bluetooth",
    "on-click": "pactl get-default-sink | xargs -I {} pactl set-sink-mute {} toggle",
    "on-click-middle": "~/.config/waybar/scripts/audio-device.sh",
    "on-click-right": "pavucontrol",
  },
  {{- if eq .device "kabuki" }}
  "battery": {
    "format": "Battery at {capacity}%",
    "format-charging": "Charging...",
    "format-full": "Battery full",
    "format-warning": "Battery dying...",
    "design-capacity": true,
  },
  {{ end }}
  "custom/space": {
    "format": " ",
    "tooltip": false,
  },
  "clock": {
    "format": "{:%I:%M %p}",
    "tooltip": true,
    "tooltip-format": "{:%d. %B on a %A}",
  },
  "tray": {
    "icon-size": 16,
    "spacing": 16,
  },
  "custom/vpn" : {
    "exec": "~/.config/waybar/scripts/vpn-manager.sh status",
    "on-click": "~/.config/waybar/scripts/vpn-manager.sh toggle",
    "interval": 5,
    "return-type": "json",
  },
  "custom/power": {
    "format": "󰐥",
    "tooltip": true,
    "tooltip-format": "Power menu (wlogout)",
    "on-click": "wlogout",
  },
  "power-profiles-daemon": {
    "format": "Profile: {icon}",
    "format-icons": {
      "balanced": "Balanced",
      "power-saver": "Chillin'",
      "performance": "Performance",
    }
  },
  "custom/updater":{
    "format": "{}",
    "exec": "~/.config/waybar/scripts/update-check.sh",
    "return-type": "json",
    "exec-if": "[[ $(checkupdates | wc -l) ]]",
    "interval": 15,
    "on-click": "~/.config/waybar/scripts/update-script.sh",
  },
}
